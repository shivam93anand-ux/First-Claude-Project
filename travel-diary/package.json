{
  "name": "travel-diary",
  "version": "1.0.0",
  "description": "A low-friction travel diary and recommendation sharing app",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite --port 5173",
    "build": "cd client && npx vite build --outDir ../server/public",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sql.js": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "concurrently": "^8.2.2"
  }
}
